# Azure / Microsoft Sentinel workspace configuration
SUBSCRIPTION_ID=
RESOURCE_GROUP=
WORKSPACE_NAME=

# LLM provider configuration
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# Safety gate. Leave false for dry-run mode.
AUTO_APPLY_CHANGES=false

# Metadata-only decision log path.
TRIAGE_AUDIT_LOG_PATH=logs/triage_audit.jsonl

# Optional local approval metadata for controlled closure-write demonstrations.
# Keep blank unless you intentionally want to demonstrate an approved write path.
TRIAGE_APPROVAL_TOKEN=
TRIAGE_APPROVER=
